@model TextMessage.Models.Message

@{
    ViewBag.Title = "The following message has been sent:";
}

<h2>@ViewBag.Title</h2>

<div>
    <h4>Message</h4>
    <hr />
    <dl class="dl-horizontal">
        <dt>
            @Html.DisplayNameFor(model => model.DestinationNumber)
        </dt>

        <dd>
            @Html.DisplayFor(model => model.DestinationNumber)
        </dd>

        <dt>
            @Html.DisplayNameFor(model => model.Content)
        </dt>

        <dd>
            @Html.DisplayFor(model => model.Content)
        </dd>

    </dl>
</div>
<p>
    @Html.ActionLink("Send another message", "SendMessage")
</p>
